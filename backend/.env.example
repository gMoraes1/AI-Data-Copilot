# Copie para .env e ajuste conforme necessário.

# --- Aplicação ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# --- Banco de dados ---
# DSN do owner/superuser (migrações, seed, histórico, usuários).
DATABASE_URL=postgresql+psycopg2://copilot:copilot@localhost:5432/copilot

# --- Multi-tenant: papel somente-leitura usado para executar o SQL do LLM ---
# Sujeito ao Row-Level Security -> isolamento por empresa. Criado no bootstrap (dev).
DATABASE_READONLY_URL=postgresql+psycopg2://copilot_ro:copilot_ro@localhost:5432/copilot
READONLY_DB_USER=copilot_ro
READONLY_DB_PASSWORD=copilot_ro
SETUP_RLS_ON_STARTUP=true

# --- Autenticação (JWT) ---
# Gere uma chave forte em produção, ex: openssl rand -hex 32
SECRET_KEY=dev-insecure-secret-change-me-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Usuários demo criados no seed: alpha@copilot.com / beta@copilot.com (senha admin123)

# --- Segurança de execução de SQL ---
SQL_MAX_ROWS=200
SQL_STATEMENT_TIMEOUT_MS=5000

# --- LLM ---
# llm_provider: "ollama" (padrão) ou "fake" (sem IA, determinístico p/ dev/testes)
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TEMPERATURE=0.0
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=60
